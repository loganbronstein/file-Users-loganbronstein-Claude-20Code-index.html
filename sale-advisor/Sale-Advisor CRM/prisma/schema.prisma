generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────

enum LeadSource {
  FACEBOOK
  INSTAGRAM
  GOOGLE
  NEXTDOOR
  TIKTOK
  REFERRAL
  LAKESHORE
  WEBSITE
  OTHER
}

enum LeadStage {
  NEW_LEAD
  CONTACTED
  WALKTHROUGH_BOOKED
  LOST
}

enum ClientStage {
  WALKTHROUGH_SCHEDULED
  WALKTHROUGH_COMPLETED
  LISTING_ACTIVE
  PARTIALLY_SOLD
  SOLD_PAID
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum DeliveryStatus {
  SCHEDULED
  PICKUP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum InventoryStatus {
  PENDING_PICKUP
  IN_POSSESSION
  LISTED
  SOLD
  DELIVERED_TO_BUYER
  RETURNED
  CANCELLED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

// ── Activity Log ────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // e.g. "lead.created", "lead.converted", "delivery.scheduled"
  detail    String?  // human-readable description
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([clientId])
  @@index([createdAt])
  @@index([action])
}

// ── Lead (pre-booking inquiry) ─────────────────────────

model Lead {
  id               String           @id @default(cuid())
  name             String
  email            String?
  phone            String?
  phoneE164        String?          @unique
  source           LeadSource       @default(OTHER)
  stage            LeadStage        @default(NEW_LEAD)
  lastContactedAt  DateTime?
  neighborhood     String?
  itemsDescription String?
  estimatedValue   Float?

  // Attribution
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmContent       String?
  utmTerm          String?
  adPlatform       String?
  campaignId       String?
  adId             String?
  landingVariant   String?

  // SMS consent
  smsConsent       Boolean          @default(false)
  consentText      String?
  consentedAt      DateTime?
  consentIp        String?
  consentUserAgent String?

  // Lifecycle
  convertedAt      DateTime?
  archivedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  messages         Message[]
  client           Client?
  conversations    Conversation[]
  activityLogs     ActivityLog[]

  @@index([stage])
  @@index([source])
  @@index([adPlatform])
  @@index([createdAt])
}

// ── Client (converted lead, walkthrough booked+) ───────

model Client {
  id             String        @id @default(cuid())
  leadId         String        @unique
  lead           Lead          @relation(fields: [leadId], references: [id])
  name           String
  email          String?
  phone          String?
  neighborhood   String?
  stage          ClientStage   @default(WALKTHROUGH_SCHEDULED)
  notes          String?

  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  messages       Message[]
  conversations  Conversation[]
  inventory      InventoryItem[]
  deliveries     Delivery[]
  payouts        Payout[]
  activityLogs   ActivityLog[]

  @@index([stage])
  @@index([createdAt])
}

// ── InventoryItem ──────────────────────────────────────

model InventoryItem {
  id             String          @id @default(cuid())
  clientId       String
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title          String
  category       String?
  condition      String?
  estValueCents  Int?
  listPriceCents Int?
  soldPriceCents Int?
  marketplace    String?
  status         InventoryStatus @default(PENDING_PICKUP)
  listedAt       DateTime?
  soldAt         DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([clientId])
  @@index([status])
}

// ── Message ────────────────────────────────────────────

model Conversation {
  id            String    @id @default(cuid())
  phoneE164     String    @unique
  leadId        String?
  lead          Lead?     @relation(fields: [leadId], references: [id])
  clientId      String?
  client        Client?   @relation(fields: [clientId], references: [id])
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages      Message[]

  @@index([lastMessageAt])
  @@index([leadId])
  @@index([clientId])
}

model Message {
  id             String           @id @default(cuid())
  content        String
  direction      MessageDirection
  read           Boolean          @default(false)
  leadId         String?
  lead           Lead?            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation?    @relation(fields: [conversationId], references: [id])
  twilioSid      String?          @unique
  status         String?
  error          String?
  idempotencyKey String?          @unique
  createdAt      DateTime         @default(now())

  @@index([leadId])
  @@index([clientId])
  @@index([conversationId])
  @@index([createdAt])
}

// ── Delivery ───────────────────────────────────────────

model Delivery {
  id             String         @id @default(cuid())
  clientId       String
  client         Client         @relation(fields: [clientId], references: [id])
  description    String
  fromAddress    String
  toAddress      String
  status         DeliveryStatus @default(SCHEDULED)
  crewSize       Int            @default(1)
  scheduledAt    DateTime?
  completedAt    DateTime?
  cost           Float?
  revenue        Float?
  idempotencyKey String?        @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([scheduledAt])
}

// ── Payout ─────────────────────────────────────────────

model Payout {
  id                String       @id @default(cuid())
  clientId          String
  client            Client       @relation(fields: [clientId], references: [id])
  grossSaleCents    Int
  deliveryFeeCents  Int          @default(0)
  commissionPercent Float
  commissionCents   Int
  payoutCents       Int
  status            PayoutStatus @default(PENDING)
  paidAt            DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([clientId])
  @@index([status])
}

// ── User (admin auth) ─────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}
