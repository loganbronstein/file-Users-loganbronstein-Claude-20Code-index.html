generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────

enum LeadSource {
  FACEBOOK
  INSTAGRAM
  GOOGLE
  NEXTDOOR
  TIKTOK
  REFERRAL
  LAKESHORE
  WEBSITE
  OTHER
}

enum LeadStage {
  NEW_LEAD
  CONTACTED
  WALKTHROUGH_BOOKED
  LOST
}

enum ClientStage {
  WALKTHROUGH_SCHEDULED
  WALKTHROUGH_COMPLETED
  LISTING_ACTIVE
  PARTIALLY_SOLD
  SOLD_PAID
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum DeliveryStatus {
  SCHEDULED
  PICKUP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum InventoryStatus {
  PENDING_PICKUP
  IN_POSSESSION
  LISTED
  SOLD
  DELIVERED_TO_BUYER
  RETURNED
  CANCELLED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum ListingStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  POSTING
  POSTED
  SOLD
  DELIVERY_SCHEDULED
  PAID_OUT
}

enum ListingSource {
  SMS
  UPLOAD
  MANUAL
}

enum UserRole {
  ADMIN
  OPS
  VIEWER
}

// ── Activity Log ────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // e.g. "lead.created", "lead.converted", "delivery.scheduled"
  detail    String?  // human-readable description
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([clientId])
  @@index([createdAt])
  @@index([action])
}

// ── Lead (pre-booking inquiry) ─────────────────────────

model Lead {
  id               String           @id @default(cuid())
  name             String
  email            String?
  phone            String?
  phoneE164        String?          @unique
  source           LeadSource       @default(OTHER)
  stage            LeadStage        @default(NEW_LEAD)
  lastContactedAt  DateTime?
  neighborhood     String?
  itemsDescription String?
  estimatedValue   Float?

  // Attribution
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmContent       String?
  utmTerm          String?
  adPlatform       String?
  campaignId       String?
  adId             String?
  landingVariant   String?

  // SMS consent
  smsConsent       Boolean          @default(false)
  consentText      String?
  consentedAt      DateTime?
  consentIp        String?
  consentUserAgent String?

  // Lifecycle
  convertedAt      DateTime?
  archivedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  messages         Message[]
  client           Client?
  conversations    Conversation[]
  activityLogs     ActivityLog[]

  @@index([stage])
  @@index([source])
  @@index([adPlatform])
  @@index([createdAt])
}

// ── Client (converted lead, walkthrough booked+) ───────

model Client {
  id             String        @id @default(cuid())
  leadId         String        @unique
  lead           Lead          @relation(fields: [leadId], references: [id])
  name           String
  email          String?
  phone          String?
  neighborhood   String?
  stage          ClientStage   @default(WALKTHROUGH_SCHEDULED)
  notes          String?

  walkthroughDate    DateTime?
  walkthroughAddress String?
  walkthroughNotes   String?

  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  messages       Message[]
  conversations  Conversation[]
  inventory      InventoryItem[]
  deliveries     Delivery[]
  payouts        Payout[]
  listings       Listing[]
  activityLogs   ActivityLog[]

  @@index([stage])
  @@index([createdAt])
}

// ── InventoryItem ──────────────────────────────────────

model InventoryItem {
  id             String          @id @default(cuid())
  clientId       String
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title          String
  category       String?
  condition      String?
  estValueCents  Int?
  listPriceCents Int?
  soldPriceCents Int?
  marketplace    String?
  status         InventoryStatus @default(PENDING_PICKUP)
  listedAt       DateTime?
  soldAt         DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  listing        Listing?

  @@index([clientId])
  @@index([status])
}

// ── Message ────────────────────────────────────────────

model Conversation {
  id            String    @id @default(cuid())
  phoneE164     String    @unique
  leadId        String?
  lead          Lead?     @relation(fields: [leadId], references: [id])
  clientId      String?
  client        Client?   @relation(fields: [clientId], references: [id])
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages      Message[]

  @@index([lastMessageAt])
  @@index([leadId])
  @@index([clientId])
}

model Message {
  id             String           @id @default(cuid())
  content        String
  direction      MessageDirection
  read           Boolean          @default(false)
  leadId         String?
  lead           Lead?            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation?    @relation(fields: [conversationId], references: [id])
  twilioSid      String?          @unique
  status         String?
  error          String?
  idempotencyKey String?          @unique
  createdAt      DateTime         @default(now())

  @@index([leadId])
  @@index([clientId])
  @@index([conversationId])
  @@index([createdAt])
}

// ── Delivery ───────────────────────────────────────────

model Delivery {
  id             String         @id @default(cuid())
  clientId       String
  client         Client         @relation(fields: [clientId], references: [id])
  description    String
  fromAddress    String
  toAddress      String
  status         DeliveryStatus @default(SCHEDULED)
  crewSize       Int            @default(1)
  scheduledAt    DateTime?
  completedAt    DateTime?
  cost           Float?
  revenue        Float?
  idempotencyKey String?        @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([scheduledAt])
}

// ── Payout ─────────────────────────────────────────────

model Payout {
  id                String       @id @default(cuid())
  clientId          String
  client            Client       @relation(fields: [clientId], references: [id])
  grossSaleCents    Int
  deliveryFeeCents  Int          @default(0)
  commissionPercent Float
  commissionCents   Int
  payoutCents       Int
  status            PayoutStatus @default(PENDING)
  paidAt            DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([clientId])
  @@index([status])
}

// ── Listing (marketplace post) ───────────────────────────

model Listing {
  id              String        @id @default(cuid())
  clientId        String?
  client          Client?       @relation(fields: [clientId], references: [id])
  inventoryItemId String?       @unique
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  title           String
  description     String
  priceCents      Int
  category        String?
  condition       String?

  images          String[]      // Supabase Storage URLs
  status          ListingStatus @default(DRAFT)
  source          ListingSource @default(MANUAL)
  aiGenerated     Boolean       @default(false)

  marketplaces    String[]      // ["facebook", "ebay", "craigslist", "offerup"]
  postedAt        DateTime?
  soldAt          DateTime?

  // Buyer + delivery tracking
  buyerName       String?
  buyerContact    String?
  deliveryStatus  String?       // free-form: "scheduled", "in_transit", "delivered"
  deliveryDate    DateTime?

  // Payout tracking
  payoutStatus    String?       // "pending", "processing", "paid"
  payoutAmountCents Int?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  soldPriceCents   Int?
  soldMarketplace  String?       // which marketplace it sold on

  listingImages    ListingImage[]
  events           ListingEvent[]
  audits           ListingAudit[]
  marketplacePosts MarketplacePost[]

  @@index([status])
  @@index([clientId])
  @@index([source])
}

// ── ListingImage (individual image metadata) ───────────────

model ListingImage {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url         String
  filename    String?
  contentType String?
  sizeBytes   Int?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([listingId])
}

// ── ListingEvent (status change log) ───────────────────────

model ListingEvent {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  action      String   // e.g. "status.draft", "status.approved", "ai.generated", "marketplace.posted"
  fromStatus  String?
  toStatus    String?
  detail      String?  // human-readable
  metadata    String?  // JSON blob for extra context
  createdAt   DateTime @default(now())

  @@index([listingId])
  @@index([createdAt])
}

// ── ListingAudit (field-level change tracking) ─────────────

model ListingAudit {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  field       String   // which field changed
  oldValue    String?
  newValue    String?
  changedBy   String?  // user email or "system"
  createdAt   DateTime @default(now())

  @@index([listingId])
  @@index([createdAt])
}

// ── Auth (NextAuth Prisma Adapter) ───────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(VIEWER)
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Campaign (ad campaign tracker) ────────────────────────

model Campaign {
  id              String    @id @default(cuid())
  name            String
  platform        String    // "meta", "google", "tiktok", "nextdoor", "other"
  status          String    @default("DRAFT") // DRAFT, ACTIVE, PAUSED, COMPLETED
  budgetCents     Int?
  startDate       DateTime?
  endDate         DateTime?
  targetAudience  String?
  notes           String?
  utmCampaign     String?   // links to Lead.utmCampaign for attribution
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([platform])
}

// ── MarketplacePost (per-marketplace posting tracker) ──────

model MarketplacePost {
  id          String    @id @default(cuid())
  listingId   String
  listing     Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  marketplace String    // "facebook", "ebay", "craigslist", "offerup"
  status      String    @default("PENDING") // PENDING, POSTED, FAILED, REMOVED
  externalUrl String?
  externalId  String?
  formattedTitle       String?
  formattedDescription String?
  postedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([listingId])
  @@index([marketplace])
  @@unique([listingId, marketplace])
}
