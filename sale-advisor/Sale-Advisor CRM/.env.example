# Supabase Postgres connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Resend — required for magic link login emails
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Sale Advisor <noreply@saleadvisor.com>"

# Authorized login emails (comma-separated, lowercase)
ALLOWED_EMAILS=you@saleadvisor.com,teammate@saleadvisor.com

# Webhook ingest secret
INGEST_SECRET="generate-with-openssl-rand-hex-16"

# Webhook HMAC secret for external lead intake (website forms, Zapier, etc.)
WEBHOOK_SECRET="generate-with-openssl-rand-hex-32"

# Twilio — required for SMS
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_FROM_NUMBER="+15551234567"

# Admin notification — YOUR phone number (gets notified on new leads + inbound SMS)
MY_NOTIFY_NUMBER="+15559876543"

# Supabase Storage — required for listing image uploads
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Anthropic — required for AI listing generation
ANTHROPIC_API_KEY="sk-ant-..."
