# Supabase Postgres connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Webhook ingest secret
INGEST_SECRET="generate-with-openssl-rand-hex-16"

# Twilio — required for SMS
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_FROM_NUMBER="+15551234567"

# Admin notification — YOUR phone number (gets notified on new leads + inbound SMS)
MY_NOTIFY_NUMBER="+15559876543"
